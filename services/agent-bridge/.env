# Copy to .env and fill in your values

# Anthropic API key (required for real execution)
ANTHROPIC_API_KEY=sk-ant-...

# URL of the Next.js backend (running on your laptop or LAN)
BACKEND_URL=http://localhost:3000

# Set to "true" to use mock execution instead of real Claude computer use
USE_MOCK=true

# Optional: Claude model to use for computer use
CLAUDE_MODEL=claude-opus-4-5-20251101
